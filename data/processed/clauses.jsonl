{"clause_id":"CL-001","text":"Synthetic clause (not official legal text): Providers of AI systems that interact with natural persons through natural-language interfaces must notify users that they are interacting with an AI system, unless such disclosure is apparent from context. Research-exempt systems are excluded.","source_instrument":"Synthetic","thematic_group":"Transparency and information","scope_risk_levels":["HighRisk","LimitedRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-001-1","clause_id":"CL-001","actor":"Provider","action":"ACT-NotifyUsersOfNLP","conditions":[{"condition_id":"C-001-1","predicate":"capability","value":"NLP","negated":false,"description":"System uses NLP capability"},{"condition_id":"C-001-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"},{"condition_id":"C-001-3","predicate":"affectsNaturalPerson","value":true,"negated":false,"description":"System interacts with persons"}],"exceptions":[{"exception_id":"X-001-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption applies"}],"required_evidence":[{"evidence_id":"E-UserNotificationPolicy","label":"E-UserNotificationPolicy","description":"","mandatory":true},{"evidence_id":"E-DeploymentRecord","label":"E-DeploymentRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-002","text":"Synthetic clause: Providers of high-risk AI systems must maintain comprehensive technical documentation throughout the system lifecycle. This obligation applies regardless of deployment status once the system has been placed on the market.","source_instrument":"Synthetic","thematic_group":"Transparency and information","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-002-1","clause_id":"CL-002","actor":"Provider","action":"ACT-MaintainTechnicalDocumentation","conditions":[{"condition_id":"C-002-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-002-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-TechnicalDocumentation","label":"E-TechnicalDocumentation","description":"","mandatory":true},{"evidence_id":"E-RiskAssessment","label":"E-RiskAssessment","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-003","text":"Synthetic clause: Providers of high-risk AI systems must provide deployers with instructions for use that enable safe and intended deployment. This obligation does not apply where the provider is the exclusive user of the system.","source_instrument":"Synthetic","thematic_group":"Transparency and information","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-003-1","clause_id":"CL-003","actor":"Provider","action":"ACT-ProvideDeployerInstructions","conditions":[{"condition_id":"C-003-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-003-2","predicate":"actor","value":"Provider","negated":false,"description":"Role is provider"}],"exceptions":[{"exception_id":"X-003-1","predicate":"isExclusiveSelfUse","value":true,"description":"Provider is sole user"}],"required_evidence":[{"evidence_id":"E-DeployerInstructions","label":"E-DeployerInstructions","description":"","mandatory":true},{"evidence_id":"E-SystemCard","label":"E-SystemCard","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-004","text":"Synthetic clause: Providers deploying systems with generative AI capabilities must disclose to end users, at the point of interaction, that content is AI-generated, and must maintain a content policy governing generated outputs.","source_instrument":"Synthetic","thematic_group":"Transparency and information","scope_risk_levels":["LimitedRisk","HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-004-1","clause_id":"CL-004","actor":"Provider","action":"ACT-DiscloseGenerativeAICapabilities","conditions":[{"condition_id":"C-004-1","predicate":"capability","value":"GenerativeAI","negated":false,"description":"System is generative AI"},{"condition_id":"C-004-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-CapabilityDisclosure","label":"E-CapabilityDisclosure","description":"","mandatory":true},{"evidence_id":"E-ContentPolicy","label":"E-ContentPolicy","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-005","text":"Synthetic clause: Providers of high-risk AI systems exhibiting systemic risk must notify the relevant national authority of any serious incident or malfunction within prescribed timeframes after the system is deployed.","source_instrument":"Synthetic","thematic_group":"Transparency and information","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-005-1","clause_id":"CL-005","actor":"Provider","action":"ACT-NotifyIncidentsToAuthority","conditions":[{"condition_id":"C-005-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-005-2","predicate":"hasSystemicRisk","value":true,"negated":false,"description":"System has systemic risk"},{"condition_id":"C-005-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-IncidentLog","label":"E-IncidentLog","description":"","mandatory":true},{"evidence_id":"E-NationalAuthorityContact","label":"E-NationalAuthorityContact","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-006","text":"Synthetic clause: Providers of high-risk AI systems incorporating biometric capabilities must conduct a conformity assessment procedure before placing the system on the market. Research-exempt systems are excluded.","source_instrument":"Synthetic","thematic_group":"Risk management and conformity assessment","scope_risk_levels":["HighRisk"],"scope_domains":["Biometric"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-006-1","clause_id":"CL-006","actor":"Provider","action":"ACT-ConductConformityAssessment","conditions":[{"condition_id":"C-006-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-006-2","predicate":"capability","value":"Biometric","negated":false,"description":"System uses biometrics"},{"condition_id":"C-006-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-006-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-ConformityAssessment","label":"E-ConformityAssessment","description":"","mandatory":true},{"evidence_id":"E-CertificationDocument","label":"E-CertificationDocument","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-007","text":"Synthetic clause: Providers of high-risk AI systems must implement, document, and maintain a risk management system throughout the system lifecycle, covering foreseeable risks to health, safety, and fundamental rights.","source_instrument":"Synthetic","thematic_group":"Risk management and conformity assessment","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-007-1","clause_id":"CL-007","actor":"Provider","action":"ACT-ImplementRiskManagementSystem","conditions":[{"condition_id":"C-007-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-007-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-RiskManagementPlan","label":"E-RiskManagementPlan","description":"","mandatory":true},{"evidence_id":"E-RiskAssessment","label":"E-RiskAssessment","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-008","text":"Synthetic clause: Providers of high-risk AI systems deployed in healthcare contexts must conduct post-market monitoring to detect adverse events and update the risk management documentation accordingly.","source_instrument":"Synthetic","thematic_group":"Risk management and conformity assessment","scope_risk_levels":["HighRisk"],"scope_domains":["Healthcare"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-008-1","clause_id":"CL-008","actor":"Provider","action":"ACT-ConductPostMarketMonitoring","conditions":[{"condition_id":"C-008-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-008-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"},{"condition_id":"C-008-3","predicate":"domain","value":"Healthcare","negated":false,"description":"Domain is healthcare"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-MonitoringPlan","label":"E-MonitoringPlan","description":"","mandatory":true},{"evidence_id":"E-PostMarketReport","label":"E-PostMarketReport","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-009","text":"Synthetic clause [AMBIGUOUS — 'where appropriate']: Providers of high-risk AI systems with systemic risk characteristics should, where appropriate, undergo third-party audits by accredited conformity assessment bodies. The phrase 'where appropriate' introduces activation ambiguity: it may require case-by-case determination by the competent authority.","source_instrument":"Synthetic","thematic_group":"Risk management and conformity assessment","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-009-1","clause_id":"CL-009","actor":"Provider","action":"ACT-UndergoThirdPartyAudit","conditions":[{"condition_id":"C-009-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-009-2","predicate":"hasSystemicRisk","value":true,"negated":false,"description":"System has systemic risk"}],"exceptions":[{"exception_id":"X-009-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-AuditReport","label":"E-AuditReport","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Ambiguous activation: 'where appropriate' requires authority determination"}],"notes":"AMBIGUITY: 'where appropriate' is interpretive. Canonical tie-breaking (gold oracle): treat as mandatory when hasSystemicRisk=True. LEXON strict logic: activates on conditions without canonical disambiguation, may yield false negatives on profiles where systemic risk is borderline."}
{"clause_id":"CL-010","text":"Synthetic clause [AMBIGUOUS — dual actor]: High-risk AI system providers must ensure deployer compliance with obligations, and deployers must implement provider instructions. The scope boundary between provider and deployer obligations is not fully specified in all deployment configurations.","source_instrument":"Synthetic","thematic_group":"Risk management and conformity assessment","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-010-1","clause_id":"CL-010","actor":"Provider","action":"ACT-EnsureDeployerCompliance","conditions":[{"condition_id":"C-010-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-010-2","predicate":"actor","value":"Provider","negated":false,"description":"Role is provider"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-DeployerAgreement","label":"E-DeployerAgreement","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Actor-attribution ambiguity: dual-actor clause"},{"obligation_id":"OBL-010-2","clause_id":"CL-010","actor":"Deployer","action":"ACT-ImplementProviderInstructions","conditions":[{"condition_id":"C-010-3","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-010-4","predicate":"actor","value":"Deployer","negated":false,"description":"Role is deployer"}],"exceptions":[{"exception_id":"X-010-1","predicate":"isExclusiveSelfUse","value":true,"description":"Provider is sole user"}],"required_evidence":[{"evidence_id":"E-ImplementationRecord","label":"E-ImplementationRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Actor-attribution ambiguity: may conflict with OBL-010-1 scope"}],"notes":"AMBIGUITY: Dual-actor clause. Canonical tie-breaking: provider obligation always activates; deployer obligation activates unless isExclusiveSelfUse=True. LEXON actor-attribution errors occur on profiles with Mixed actor."}
{"clause_id":"CL-011","text":"Synthetic clause: Providers of AI systems that incorporate biometric processing capabilities must implement data minimization measures limiting biometric data collection to what is strictly necessary for the declared purpose.","source_instrument":"Synthetic","thematic_group":"Special-category data handling","scope_risk_levels":["HighRisk","LimitedRisk"],"scope_domains":["Biometric"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-011-1","clause_id":"CL-011","actor":"Provider","action":"ACT-MinimizeBiometricData","conditions":[{"condition_id":"C-011-1","predicate":"capability","value":"Biometric","negated":false,"description":"System uses biometrics"},{"condition_id":"C-011-2","predicate":"processesSpecialCategory","value":true,"negated":false,"description":"Processes special data"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-DataMinimizationPolicy","label":"E-DataMinimizationPolicy","description":"","mandatory":true},{"evidence_id":"E-PrivacyImpactAssessment","label":"E-PrivacyImpactAssessment","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-012","text":"Synthetic clause: Providers deploying AI systems that process special-category personal data must conduct a data protection impact assessment prior to deployment, unless a research exemption applies.","source_instrument":"Synthetic","thematic_group":"Special-category data handling","scope_risk_levels":["HighRisk","LimitedRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-012-1","clause_id":"CL-012","actor":"Provider","action":"ACT-ConductDPIA","conditions":[{"condition_id":"C-012-1","predicate":"processesSpecialCategory","value":true,"negated":false,"description":"Processes special data"},{"condition_id":"C-012-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-012-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-PrivacyImpactAssessment","label":"E-PrivacyImpactAssessment","description":"","mandatory":true},{"evidence_id":"E-DataProcessingAgreement","label":"E-DataProcessingAgreement","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-013","text":"Synthetic clause [AMBIGUOUS — 'adequate protection']: Providers of AI systems deployed in the EU market that involve international transfer of special-category data must ensure adequate protection for such transfers. The scope of 'adequate protection' requires case-by-case legal assessment.","source_instrument":"Synthetic","thematic_group":"Special-category data handling","scope_risk_levels":["HighRisk","LimitedRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-013-1","clause_id":"CL-013","actor":"Provider","action":"ACT-EnsureDataTransferProtection","conditions":[{"condition_id":"C-013-1","predicate":"processesSpecialCategory","value":true,"negated":false,"description":"Processes special data"},{"condition_id":"C-013-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"Deployed in EU market"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-DataTransferMechanism","label":"E-DataTransferMechanism","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Vocabulary mismatch: 'adequate protection' scope ambiguity"}],"notes":"AMBIGUITY: 'adequate protection' is interpretive. Canonical tie-breaking: mandatory when processesSpecialCategory=True AND deployment=EU_Market. LEXON errors: vocabulary mismatch on non-standard transfer mechanisms."}
{"clause_id":"CL-014","text":"Synthetic clause: Providers of AI systems that affect natural persons through processing of special-category data must implement procedures enabling data subjects to exercise their rights of access, rectification, and erasure.","source_instrument":"Synthetic","thematic_group":"Special-category data handling","scope_risk_levels":["HighRisk","LimitedRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-014-1","clause_id":"CL-014","actor":"Provider","action":"ACT-SupportDataSubjectRights","conditions":[{"condition_id":"C-014-1","predicate":"processesSpecialCategory","value":true,"negated":false,"description":"Processes special data"},{"condition_id":"C-014-2","predicate":"affectsNaturalPerson","value":true,"negated":false,"description":"Affects natural persons"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-DataSubjectRightsPolicy","label":"E-DataSubjectRightsPolicy","description":"","mandatory":true},{"evidence_id":"E-ConsentRecord","label":"E-ConsentRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-015","text":"Synthetic clause [AMBIGUOUS — research exemption boundary]: Providers of AI systems in research domains must register the system with the relevant authority unless the system qualifies for a research exemption. The boundary of the research exemption for commercial research activities is not fully specified.","source_instrument":"Synthetic","thematic_group":"Special-category data handling","scope_risk_levels":["MinimalRisk","LimitedRisk"],"scope_domains":["Research"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-015-1","clause_id":"CL-015","actor":"Provider","action":"ACT-RegisterResearchUse","conditions":[{"condition_id":"C-015-1","predicate":"domain","value":"Research","negated":false,"description":"Domain is research"},{"condition_id":"C-015-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-015-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-ResearchRegistration","label":"E-ResearchRegistration","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Exception-scope mis-attribution risk for commercial research"}],"notes":"AMBIGUITY: Research exemption scope for commercial research is unclear. Canonical tie-breaking: hasResearchExemption=True suppresses obligation. LEXON errors: exception-scope mis-attribution on commercial research profiles."}
{"clause_id":"CL-016","text":"Synthetic clause: Providers of high-risk AI systems with decision-support capabilities must implement a human override capability enabling authorised operators to interrupt, override, or shut down the system.","source_instrument":"Synthetic","thematic_group":"Human oversight and human-in-the-loop","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-016-1","clause_id":"CL-016","actor":"Provider","action":"ACT-ImplementHumanOverride","conditions":[{"condition_id":"C-016-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-016-2","predicate":"capability","value":"DecisionSupport","negated":false,"description":"System supports decisions"},{"condition_id":"C-016-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-HumanOverrideDoc","label":"E-HumanOverrideDoc","description":"","mandatory":true},{"evidence_id":"E-OverrideProcedure","label":"E-OverrideProcedure","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-017","text":"Synthetic clause: Deployers of high-risk AI systems with decision-support capabilities affecting natural persons must ensure that a qualified human reviews automated decisions before they are implemented.","source_instrument":"Synthetic","thematic_group":"Human oversight and human-in-the-loop","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-017-1","clause_id":"CL-017","actor":"Deployer","action":"ACT-ConductHumanReview","conditions":[{"condition_id":"C-017-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-017-2","predicate":"capability","value":"DecisionSupport","negated":false,"description":"System supports decisions"},{"condition_id":"C-017-3","predicate":"affectsNaturalPerson","value":true,"negated":false,"description":"Affects natural persons"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-HumanReviewRecord","label":"E-HumanReviewRecord","description":"","mandatory":true},{"evidence_id":"E-HumanReviewPolicy","label":"E-HumanReviewPolicy","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""}],"notes":""}
{"clause_id":"CL-018","text":"Synthetic clause [AMBIGUOUS — override vs. monitoring threshold]: High-risk AI system providers must implement either full human override capability or a real-time monitoring mechanism, depending on operational context. The threshold between requiring override versus monitoring is not precisely specified.","source_instrument":"Synthetic","thematic_group":"Human oversight and human-in-the-loop","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-018-1","clause_id":"CL-018","actor":"Provider","action":"ACT-ImplementHumanOversight","conditions":[{"condition_id":"C-018-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-018-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-018-1","predicate":"capability","value":"GenerativeAI","description":"GenAI may use monitoring instead of full override"}],"required_evidence":[{"evidence_id":"E-HumanOversightDoc","label":"E-HumanOversightDoc","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Ambiguous: override vs. monitoring threshold unclear"}],"notes":"AMBIGUITY: Override vs. monitoring threshold is interpretive. Canonical tie-breaking: activate for all HighRisk deployed systems. Exception: GenerativeAI systems may use monitoring instead of override. LEXON errors: vocabulary ambiguity on combined override-monitoring obligation."}
{"clause_id":"CL-019","text":"Synthetic clause: Providers of high-risk AI systems with audit logging under operator control must document human-in-the-loop procedures and maintain records of oversight interventions.","source_instrument":"Synthetic","thematic_group":"Human oversight and human-in-the-loop","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-019-1","clause_id":"CL-019","actor":"Provider","action":"ACT-DocumentHITLProcedures","conditions":[{"condition_id":"C-019-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-019-2","predicate":"logsUnderControl","value":true,"negated":false,"description":"Logs under operator control"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-HITLProcedureDoc","label":"E-HITLProcedureDoc","description":"","mandatory":true},{"evidence_id":"E-OversightLog","label":"E-OversightLog","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""},{"obligation_id":"OBL-019-CF1","clause_id":"CL-019","actor":"Provider","action":"ACT-RequireHumanOverride","conditions":[{"condition_id":"C-019-CF1-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-019-CF1-2","predicate":"logsUnderControl","value":true,"negated":false,"description":"Logs under operator control"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-OverrideProcedure","label":"E-OverrideProcedure","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: HITL compliance requires human override enforcement for all automated outputs where logs are under control. Creates cross-clause conflicts with ACT-FullAutomatedDecision obligations."},{"obligation_id":"OBL-019-CF2","clause_id":"CL-019","actor":"Provider","action":"ACT-MinimiseDataRetention","conditions":[{"condition_id":"C-019-CF2-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-019-CF2-2","predicate":"logsUnderControl","value":true,"negated":false,"description":"Logs under operator control"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-DataMinimizationPolicy","label":"E-DataMinimizationPolicy","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: HITL log-control obligations require strict data minimisation. Creates cross-clause conflicts with ACT-RetainDataMaximal obligations."}],"notes":""}
{"clause_id":"CL-020","text":"Synthetic clause [AMBIGUOUS — 'sufficient oversight']: Deployers of high-risk AI systems affecting natural persons must demonstrate sufficient oversight of AI-assisted decisions. The standard for 'sufficiency' is not quantitatively defined and requires contextual assessment.","source_instrument":"Synthetic","thematic_group":"Human oversight and human-in-the-loop","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-020-1","clause_id":"CL-020","actor":"Deployer","action":"ACT-DemonstrateOversight","conditions":[{"condition_id":"C-020-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-020-2","predicate":"actor","value":"Deployer","negated":false,"description":"Role is deployer"},{"condition_id":"C-020-3","predicate":"affectsNaturalPerson","value":true,"negated":false,"description":"Affects natural persons"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-OversightDemonstrationRecord","label":"E-OversightDemonstrationRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Actor-attribution ambiguity: deployer vs. provider split"}],"notes":"AMBIGUITY: 'Sufficient oversight' is interpretive. Canonical tie-breaking: activate when Deployer + HighRisk + affectsNaturalPerson. LEXON errors: actor-attribution errors on dual-role profiles."}
{"clause_id":"CL-021","text":"Synthetic clause: Providers of high-risk AI systems deployed in the EU market must map their technical and organisational controls to the NIST AI Risk Management Framework governance functions and maintain a current control registry.","source_instrument":"Synthetic","thematic_group":"Cross-instrument provisions","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-021-1","clause_id":"CL-021","actor":"Provider","action":"ACT-MapControlsToNIST","conditions":[{"condition_id":"C-021-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-021-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-NISTMapping","label":"E-NISTMapping","description":"","mandatory":true},{"evidence_id":"E-ControlRegistry","label":"E-ControlRegistry","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""},{"obligation_id":"OBL-021-CF1","clause_id":"CL-021","actor":"Provider","action":"ACT-FullAutomatedDecision","conditions":[{"condition_id":"C-021-CF1-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-021-CF1-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"}],"exceptions":[],"required_evidence":[],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: NIST AI RMF governance permits automated decision pathways when documented controls are in place. Creates cross-clause conflicts with ACT-RequireHumanOverride obligations."},{"obligation_id":"OBL-021-CF2","clause_id":"CL-021","actor":"Provider","action":"ACT-RetainDataMaximal","conditions":[{"condition_id":"C-021-CF2-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-021-CF2-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"},{"condition_id":"C-021-CF2-3","predicate":"processesSpecialCategory","value":true,"negated":false,"description":"Processes special-category data"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-ControlRegistry","label":"E-ControlRegistry","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: NIST AI RMF governance requires retaining comprehensive data for accountability analysis when special-category data is involved. Creates cross-clause conflicts with ACT-MinimiseDataRetention and ACT-ConductDPIA obligations."},{"obligation_id":"OBL-021-CF3","clause_id":"CL-021","actor":"Provider","action":"ACT-DiscloseToPublic","conditions":[{"condition_id":"C-021-CF3-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-021-CF3-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"},{"condition_id":"C-021-CF3-3","predicate":"hasSystemicRisk","value":true,"negated":false,"description":"System poses systemic risk"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-NISTMapping","label":"E-NISTMapping","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: NIST AI RMF accountability requires public disclosure for systemic-risk systems. Creates cross-clause conflicts with ACT-MaintainConfidentiality obligations."}],"notes":""}
{"clause_id":"CL-022","text":"Synthetic clause: Providers of high-risk AI systems that are deployed must align their AI management systems with the requirements of ISO/IEC 42001 and document the alignment.","source_instrument":"Synthetic","thematic_group":"Cross-instrument provisions","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-022-1","clause_id":"CL-022","actor":"Provider","action":"ACT-AlignWithISO42001","conditions":[{"condition_id":"C-022-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-022-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-ISO42001Certificate","label":"E-ISO42001Certificate","description":"","mandatory":true},{"evidence_id":"E-AIManagementSystem","label":"E-AIManagementSystem","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""},{"obligation_id":"OBL-022-CF1","clause_id":"CL-022","actor":"Provider","action":"ACT-FullAutomatedDecision","conditions":[{"condition_id":"C-022-CF1-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-022-CF1-2","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[],"required_evidence":[],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: ISO 42001 management system controls may permit automated decision channels when management system evidence is documented. Creates cross-clause conflicts with ACT-RequireHumanOverride."},{"obligation_id":"OBL-022-CF2","clause_id":"CL-022","actor":"Provider","action":"ACT-RetainDataMaximal","conditions":[{"condition_id":"C-022-CF2-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"conditio