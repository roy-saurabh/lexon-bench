ument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation (in ambiguous clause): AI Act + GDPR dual compliance may permit automated processing when adequate safeguards are documented under both instruments. Creates cross-clause conflicts with ACT-RequireHumanOverride obligations."}],"notes":"AMBIGUITY: AI Act + GDPR interaction is not fully specified. Canonical tie-breaking: activate when all three conditions satisfied. LEXON errors: vocabulary mismatch on dual-compliance evidence specification."}
{"clause_id":"CL-024","text":"Synthetic clause: Providers of high-risk AI systems deployed in the EU market must register the system with the relevant national AI authority, unless the system qualifies for a research exemption.","source_instrument":"Synthetic","thematic_group":"Cross-instrument provisions","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":false,"obligations":[{"obligation_id":"OBL-024-1","clause_id":"CL-024","actor":"Provider","action":"ACT-NotifyNationalAuthority","conditions":[{"condition_id":"C-024-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-024-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"},{"condition_id":"C-024-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-024-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-NationalAuthorityContact","label":"E-NationalAuthorityContact","description":"","mandatory":true},{"evidence_id":"E-RegistrationRecord","label":"E-RegistrationRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":""},{"obligation_id":"OBL-024-CF1","clause_id":"CL-024","actor":"Provider","action":"ACT-MaintainConfidentiality","conditions":[{"condition_id":"C-024-CF1-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-024-CF1-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"},{"condition_id":"C-024-CF1-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-024-CF1-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-RegistrationRecord","label":"E-RegistrationRecord","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: EU-registered providers may claim confidentiality of proprietary system details included in registration. Creates cross-clause conflicts with ACT-DiscloseToPublic obligations."},{"obligation_id":"OBL-024-CF2","clause_id":"CL-024","actor":"Provider","action":"ACT-RequireHumanOverride","conditions":[{"condition_id":"C-024-CF2-1","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-024-CF2-2","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"},{"condition_id":"C-024-CF2-3","predicate":"isDeployed","value":true,"negated":false,"description":"System is deployed"}],"exceptions":[{"exception_id":"X-024-CF2-1","predicate":"hasResearchExemption","value":true,"description":"Research exemption"}],"required_evidence":[{"evidence_id":"E-OverrideProcedure","label":"E-OverrideProcedure","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":false,"notes":"Conflict-forming obligation: EU national authority registration includes attestation that human override is required for all automated decisions affecting registered activities. Creates cross-clause conflicts with ACT-FullAutomatedDecision obligations."}],"notes":""}
{"clause_id":"CL-025","text":"Synthetic clause [AMBIGUOUS — equivalence]: Importers of high-risk AI systems from non-EU jurisdictions and deploying in the EU market must assess whether the system meets standards equivalent to EU requirements. The standard of equivalence is not defined for all third-country regulatory frameworks.","source_instrument":"Synthetic","thematic_group":"Cross-instrument provisions","scope_risk_levels":["HighRisk"],"scope_domains":["General"],"ambiguity_flag":true,"obligations":[{"obligation_id":"OBL-025-1","clause_id":"CL-025","actor":"Importer","action":"ACT-AssessEquivalentCompliance","conditions":[{"condition_id":"C-025-1","predicate":"actor","value":"Importer","negated":false,"description":"Role is importer"},{"condition_id":"C-025-2","predicate":"risk_level","value":"HighRisk","negated":false,"description":"System is high-risk"},{"condition_id":"C-025-3","predicate":"deployment_context","value":"EU_Market","negated":false,"description":"EU market deployment"}],"exceptions":[],"required_evidence":[{"evidence_id":"E-EquivalenceAssessment","label":"E-EquivalenceAssessment","description":"","mandatory":true}],"source_instrument":"Synthetic","ambiguity_flag":true,"notes":"Actor-attribution ambiguity: Importer role not always specified"}],"notes":"AMBIGUITY: Equivalence standard undefined for many third-country frameworks. Canonical tie-breaking: activate when actor=Importer, HighRisk, EU_Market. LEXON errors: actor-attribution errors on Importer profiles with Mixed deployment."}
