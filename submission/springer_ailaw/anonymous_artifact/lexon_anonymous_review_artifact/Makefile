.PHONY: setup test reproduce tables figures supplement clean check-integrity \
        generate run-lexon run-baselines evaluate \
        validate traces validate-mapping ailaw-artifact-check \
        blind-check springer-style-check anonymous-artifact \
        ailaw-submission-check help

PYTHON  ?= python
UV      := uv
LEX     := lexon

help:
	@echo ""
	@echo "LEXON-Bench — Makefile targets"
	@echo "==============================="
	@echo "  make setup                  Install dependencies (uv)"
	@echo "  make test                   Run pytest test suite"
	@echo "  make reproduce              Full reproduction pipeline (seed=42)"
	@echo "  make tables                 Generate paper-ready tables (requires reproduce)"
	@echo "  make figures                Generate paper figures (requires reproduce)"
	@echo "  make traces                 Generate derivation trace examples"
	@echo "  make validate-mapping       Validate illustrative EU AI Act mapping"
	@echo "  make ailaw-artifact-check   Full AI&L artifact check (tests + traces + mapping)"
	@echo "  make anonymous-artifact     Build anonymized review artifact ZIP"
	@echo "  make blind-check            Scan anonymous files for forbidden identifiers"
	@echo "  make springer-style-check   Check reference style and manuscript style"
	@echo "  make ailaw-submission-check Full submission readiness check"
	@echo "  make supplement             Build supplementary ZIP"
	@echo "  make clean                  Remove generated outputs"
	@echo "  make check-integrity        Run conformance suite integrity checks"
	@echo ""

# ---------------------------------------------------------------------------
setup:
	$(UV) sync
	@echo "✓ Dependencies installed"

# ---------------------------------------------------------------------------
test:
	$(UV) run pytest tests/ -v --tb=short

validate: test

# ---------------------------------------------------------------------------
generate:
	$(UV) run $(LEX) generate-benchmark --config configs/experiment_synthetic.yaml

run-lexon: generate
	$(UV) run $(LEX) run \
		--input data/processed/benchmark_instances.jsonl \
		--output outputs/results/lexon_predictions.jsonl \
		--split test

run-baselines: generate
	$(UV) run $(LEX) run-baseline checklist --split test
	$(UV) run $(LEX) run-baseline ontology-only --split test
	$(UV) run $(LEX) run-baseline flat-rules --split test

evaluate: run-lexon run-baselines
	$(UV) run $(LEX) evaluate \
		--gold data/processed/gold_labels.jsonl \
		--pred outputs/results/lexon_predictions.jsonl \
		--system-name "LEXON (full)" \
		--split test
	$(UV) run $(LEX) evaluate \
		--gold data/processed/gold_labels.jsonl \
		--pred outputs/results/checklist_predictions.jsonl \
		--system-name "B1 Static checklist" --split test
	$(UV) run $(LEX) evaluate \
		--gold data/processed/gold_labels.jsonl \
		--pred outputs/results/ontology_predictions.jsonl \
		--system-name "B2 Ontology (no rules)" --split test
	$(UV) run $(LEX) evaluate \
		--gold data/processed/gold_labels.jsonl \
		--pred outputs/results/flat_rules_predictions.jsonl \
		--system-name "B3 Flat rules (no graph)" --split test

reproduce:
	$(UV) run python scripts/reproduce_paper_results.py

tables:
	@test -f outputs/results/metrics_synthetic.csv || \
		(echo "Run 'make reproduce' first" && exit 1)
	@echo "✓ Tables already generated by reproduce pipeline"

figures:
	@test -f outputs/figures/pipeline.png || \
		(echo "Run 'make reproduce' first" && exit 1)
	@echo "✓ Figures already generated by reproduce pipeline"

# ---------------------------------------------------------------------------
traces:
	$(UV) run python scripts/generate_trace_examples.py

validate-mapping:
	$(UV) run python scripts/validate_illustrative_mapping.py

# ---------------------------------------------------------------------------
ailaw-artifact-check:
	@echo "=== LEXON AI&L artifact check ==="
	$(UV) run pytest tests/ -v --tb=short
	$(UV) run python scripts/validate_illustrative_mapping.py
	$(UV) run python scripts/generate_trace_examples.py
	$(UV) run python scripts/check_no_placeholders.py || true
	@echo "=== AI&L artifact check complete ==="

# ---------------------------------------------------------------------------
anonymous-artifact:
	$(UV) run python scripts/build_anonymous_review_artifact.py

blind-check:
	$(UV) run python scripts/check_blind_submission.py --path submission/springer_ailaw/anonymized_manuscript
	$(UV) run python scripts/check_blind_submission.py --path submission/springer_ailaw/anonymous_artifact

springer-style-check:
	$(UV) run python scripts/check_springer_reference_style.py
	$(UV) run python scripts/check_springer_manuscript_style.py

ailaw-submission-check:
	@echo "=== LEXON AI&L submission check ==="
	$(MAKE) validate
	$(MAKE) traces
	$(MAKE) validate-mapping
	$(MAKE) anonymous-artifact
	$(MAKE) blind-check
	$(MAKE) springer-style-check
	@echo "=== AI&L submission check complete ==="

# ---------------------------------------------------------------------------
supplement:
	$(UV) run $(LEX) export-supplement \
		--output outputs/lexon_supplementary.zip
	@echo "✓ Supplementary ZIP: outputs/lexon_supplementary.zip"

check-integrity:
	$(UV) run $(LEX) check-integrity

clean:
	rm -rf outputs/results/* outputs/tables/* outputs/figures/* \
		outputs/reports/* outputs/audit/* outputs/traces/* \
		data/processed/*.jsonl data/splits/*.txt
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.pyc" -delete 2>/dev/null || true
	@echo "✓ Outputs cleaned"
